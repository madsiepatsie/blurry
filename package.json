{
  "name": "blurry",
  "version": "1.0.0",
  "description": "Meticulous face blurring and tracking software",
  "main": "src/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "dist": "vite build && electron-builder"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.17",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^0.474.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.2",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "vite": "^6.0.3"
  },
  "build": {
    "appId": "com.manus.blurry",
    "productName": "Blurry",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "src/main.cjs",
      "src/preload.cjs"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "portable"
    }
  }
}
